---
import type { ViewPlatformPreview } from '../data/mobileViews';

interface Props {
  code: string;
  title: string;
  platform: 'mobile' | 'web';
  preview: ViewPlatformPreview;
}

const { code, title, platform, preview } = Astro.props;
const frameLabel = platform === 'mobile' ? 'Vista movil' : 'Vista web';
const previewAlt = preview.alt ?? `${frameLabel} de ${code} - ${title}`;
---

<figure class={`preview-card ${platform}`}>
  {preview.images && preview.images.length > 0 ? (
    preview.images.length === 1 ? (
      <img src={preview.images[0]} alt={previewAlt} loading="lazy" />
    ) : (
      <div class="image-carousel" data-image-carousel>
        <div class="image-track">
          {preview.images.map((img, i) => (
            <img
              src={img}
              alt={`${previewAlt} ${i + 1}`}
              loading="lazy"
              data-image-index={i}
            />
          ))}
        </div>
        <div class="image-controls">
          <div class="image-dots">
            {preview.images.map((_, i) => (
              <button
                class="image-dot"
                data-image-index={i}
                aria-label={`Imagen ${i + 1} de ${previewAlt}`}
              />
            ))}
          </div>
          <div class="image-selector" aria-label={`Selector de imagenes para ${previewAlt}`}>
            {preview.images.map((_, i) => (
              <button
                class="image-selector-button"
                data-image-index={i}
                type="button"
              >
                {i + 1}
              </button>
            ))}
          </div>
        </div>
      </div>
    )
  ) : (
    <div class={`preview-frame ${platform}`} aria-label={previewAlt}>
      <div class={`chrome ${platform}`}>
        {platform === 'mobile' ? (
          <span class="mobile-notch" />
        ) : (
          <>
            <span class="browser-dot red" />
            <span class="browser-dot amber" />
            <span class="browser-dot green" />
            <span class="browser-bar" />
          </>
        )}
      </div>

      <div class={`preview-body ${preview.variant}`}>
        <header>
          <span class="eyebrow">{code}</span>
          <strong>{title}</strong>
        </header>

        {preview.variant === 'auth' && (
          <>
            <div class="hero-illustration" />
            <div class="field-stack">
              <span />
              <span />
            </div>
            <div class="primary-button" />
          </>
        )}

        {preview.variant === 'intro' && (
          <>
            <div class="headline-block">
              <span />
              <span />
            </div>
            <div class="info-card">
              <span class="icon-chip" />
              <div>
                <span />
                <span />
              </div>
            </div>
            <div class="primary-button" />
          </>
        )}

        {preview.variant === 'modules' && (
          <>
            <div class="headline-block compact">
              <span />
            </div>
            <div class="toggle-list">
              <span />
              <span />
              <span />
              <span />
            </div>
            <div class="primary-button" />
          </>
        )}

        {preview.variant === 'dashboard' && (
          <>
            <div class="stat-grid">
              <span />
              <span />
              <span />
              <span />
            </div>
            <div class="list-card">
              <span />
              <span />
              <span />
            </div>
            <div class="tab-bar">
              <span />
              <span />
              <span />
              <span />
            </div>
          </>
        )}

        {preview.variant === 'list' && (
          <>
            <div class="search-bar" />
            <div class="list-card">
              <span />
              <span />
              <span />
              <span />
            </div>
            <div class="tab-bar">
              <span />
              <span />
              <span />
              <span />
            </div>
          </>
        )}

        {preview.variant === 'calendar' && (
          <>
            <div class="calendar-grid">
              {Array.from({ length: 14 }).map(() => <span />)}
            </div>
            <div class="list-card small">
              <span />
              <span />
            </div>
          </>
        )}

        {preview.variant === 'form' && (
          <>
            <div class="field-stack">
              <span />
              <span />
              <span />
              <span />
            </div>
            <div class="info-card helper">
              <span class="icon-chip" />
              <div>
                <span />
                <span />
              </div>
            </div>
            <div class="primary-button" />
          </>
        )}

        {preview.variant === 'paywall' && (
          <>
            <div class="crown-badge" />
            <div class="headline-block compact">
              <span />
              <span />
            </div>
            <div class="price-grid">
              <span />
              <span />
            </div>
            <div class="primary-button" />
          </>
        )}

        {preview.variant === 'menu' && (
          <>
            <div class="menu-header">
              <span class="avatar-dot" />
              <div>
                <span />
                <span />
              </div>
            </div>
            <div class="menu-list">
              <span />
              <span />
              <span />
              <span />
              <span />
            </div>
          </>
        )}
      </div>
    </div>
  )}
</figure>

<style>
  .preview-card {
    --preview-surface-top: rgba(255, 255, 255, 0.98);
    --preview-surface-bottom: rgba(248, 250, 252, 0.98);
    --preview-surface-accent: rgba(124, 58, 237, 0.14);
    --preview-shadow: 0 22px 44px rgba(15, 23, 42, 0.15);
    --preview-frame-border: color-mix(in srgb, var(--sl-color-accent) 28%, white 72%);
    --preview-body-start: #ffffff;
    --preview-body-end: #f5f3ff;
    --preview-title-color: #22153a;
    --preview-tag-color: #7c3aed;
    --preview-muted: rgba(148, 163, 184, 0.18);
    --preview-selector-surface: rgba(255, 255, 255, 0.82);
    --preview-selector-border: rgba(124, 58, 237, 0.12);
    --preview-selector-shadow: 0 12px 30px rgba(15, 23, 42, 0.14);
    display: grid;
    gap: 0.9rem;
    margin: 0;
    justify-items: center;
    box-sizing: border-box;
  }

  .preview-card.mobile {
    width: min(100%, clamp(15rem, 31vw, 18.5rem));
  }

  .preview-card.web {
    width: min(100%, 62rem);
  }

  .preview-card img {
    display: block;
    width: 100%;
    margin-inline: auto;
    box-sizing: border-box;
    border-radius: 2rem;
    border: 1px solid var(--sl-color-hairline);
    box-shadow: var(--preview-shadow);
    object-fit: cover;
  }

  .preview-frame {
    display: grid;
    gap: 0.75rem;
    width: 100%;
    margin-inline: auto;
    box-sizing: border-box;
    padding: 0.9rem;
    border: 1px solid var(--preview-frame-border);
    background:
      radial-gradient(circle at top left, var(--preview-surface-accent), transparent 38%),
      linear-gradient(180deg, var(--preview-surface-top), var(--preview-surface-bottom));
    box-shadow: var(--preview-shadow);
    overflow: hidden;
  }

  .preview-frame.mobile {
    border-radius: 3rem;
    aspect-ratio: 9 / 16;
  }

  .preview-frame.web {
    border-radius: 2.25rem;
    aspect-ratio: 16 / 10;
  }

  .chrome {
    display: flex;
    align-items: center;
    min-height: 1rem;
  }

  .chrome.mobile {
    justify-content: center;
  }

  .mobile-notch {
    width: 4rem;
    height: 0.55rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--sl-color-black) 88%, white 12%);
  }

  .chrome.web {
    gap: 0.35rem;
  }

  .browser-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
  }

  .browser-dot.red { background: #f87171; }
  .browser-dot.amber { background: #fbbf24; }
  .browser-dot.green { background: #4ade80; }

  .browser-bar {
    flex: 1;
    height: 0.8rem;
    margin-left: 0.35rem;
    border-radius: 999px;
    background: var(--preview-muted);
  }

  .preview-body {
    display: grid;
    gap: 0.75rem;
    min-height: 0;
    height: 100%;
    padding: 0.9rem;
    border-radius: 2.1rem;
    background: linear-gradient(180deg, var(--preview-body-start) 0%, var(--preview-body-end) 100%);
  }

  .preview-body header {
    display: grid;
    gap: 0.2rem;
  }

  .preview-body strong {
    font-size: 0.92rem;
    color: var(--preview-title-color);
  }

  .preview-body small,
  .eyebrow {
    color: var(--preview-tag-color);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-illustration,
  .crown-badge {
    justify-self: center;
    width: min(45%, 5.2rem);
    aspect-ratio: 1;
    border-radius: 999px;
    background:
      radial-gradient(circle at 35% 35%, #fde68a, #f59e0b 65%),
      #fef3c7;
  }

  .hero-illustration {
    background:
      radial-gradient(circle at 35% 35%, #c4b5fd, #7c3aed 65%),
      #ede9fe;
  }

  .headline-block,
  .field-stack,
  .toggle-list,
  .list-card,
  .menu-list,
  .calendar-grid,
  .price-grid,
  .stat-grid {
    display: grid;
    gap: 0.45rem;
  }

  .headline-block span,
  .field-stack span,
  .toggle-list span,
  .list-card span,
  .menu-list span,
  .price-grid span,
  .menu-header span,
  .calendar-grid span,
  .stat-grid span,
  .search-bar,
  .primary-button,
  .info-card,
  .avatar-dot,
  .icon-chip {
    display: block;
    border-radius: 0.75rem;
  }

  .headline-block span,
  .menu-header span {
    height: 0.6rem;
    background: color-mix(in srgb, var(--preview-tag-color) 18%, transparent);
  }

  .headline-block span:last-child {
    width: 75%;
  }

  .headline-block.compact span:last-child {
    width: 55%;
  }

  .field-stack span,
  .search-bar {
    height: 0.95rem;
    background: var(--preview-muted);
  }

  .toggle-list span,
  .list-card span,
  .menu-list span {
    height: 1rem;
    background: linear-gradient(90deg, rgba(124, 58, 237, 0.12), rgba(148, 163, 184, 0.14));
  }

  .list-card.small span {
    height: 0.85rem;
  }

  .calendar-grid {
    grid-template-columns: repeat(7, minmax(0, 1fr));
  }

  .calendar-grid span {
    aspect-ratio: 1;
    background: rgba(124, 58, 237, 0.1);
    border-radius: 0.45rem;
  }

  .stat-grid,
  .price-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stat-grid span,
  .price-grid span {
    min-height: 3rem;
    background: linear-gradient(180deg, rgba(124, 58, 237, 0.15), rgba(168, 85, 247, 0.08));
  }

  .info-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.55rem;
    padding: 0.7rem;
    background: color-mix(in srgb, var(--preview-tag-color) 8%, transparent);
  }

  .info-card.helper {
    align-items: start;
  }

  .info-card div {
    display: grid;
    gap: 0.35rem;
  }

  .info-card div span {
    height: 0.55rem;
    background: color-mix(in srgb, var(--preview-tag-color) 14%, transparent);
    border-radius: 999px;
  }

  .icon-chip,
  .avatar-dot {
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 999px;
    background: linear-gradient(180deg, #a78bfa, #7c3aed);
  }

  .menu-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.55rem;
    align-items: center;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.18);
  }

  .menu-header div {
    display: grid;
    gap: 0.3rem;
  }

  .tab-bar {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.35rem;
    margin-top: auto;
  }

  .tab-bar span {
    height: 0.65rem;
    border-radius: 999px;
    background: rgba(124, 58, 237, 0.22);
  }

  .primary-button {
    height: 1.05rem;
    margin-top: auto;
    background: linear-gradient(90deg, #7c3aed, #8b5cf6);
  }

  .image-carousel {
    position: relative;
    width: 100%;
    margin-inline: auto;
    box-sizing: border-box;
    border-radius: 2.05rem;
    overflow: hidden;
    border: 1px solid var(--sl-color-hairline);
    box-shadow: var(--preview-shadow);
  }

  .image-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }

  .image-track::-webkit-scrollbar {
    display: none;
  }

  .image-track img {
    width: 100%;
    box-sizing: border-box;
    flex-shrink: 0;
    scroll-snap-align: start;
    object-fit: cover;
  }

  .image-controls {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.9rem;
    z-index: 2;
    display: flex;
    justify-content: center;
    width: 100%;
    padding: 0;
    background: transparent;
  }

  .image-dots {
    display: none;
  }

  .image-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    border: 1px solid rgba(124, 58, 237, 0.24);
    background: rgba(124, 58, 237, 0.12);
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    padding: 0;
  }

  .image-dot.active {
    background: #7c3aed;
    border-color: #7c3aed;
    transform: scale(1.3);
  }

  .image-dot:hover {
    background: rgba(124, 58, 237, 0.35);
  }

  .image-selector {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(2.2rem, 2.2rem);
    justify-content: center;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0.55rem;
    border-radius: 999px;
    background: var(--preview-selector-surface);
    border: 1px solid var(--preview-selector-border);
    box-shadow: var(--preview-selector-shadow);
    backdrop-filter: blur(10px);
  }

  .image-selector-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    padding: 0;
    border: 1px solid rgba(124, 58, 237, 0.16);
    border-radius: 999px;
    background: rgba(124, 58, 237, 0.08);
    color: #6d28d9;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, transform 0.15s, border-color 0.2s;
  }

  .image-selector-button:hover {
    background: rgba(124, 58, 237, 0.16);
    transform: translateY(-1px);
  }

  .image-selector-button.active {
    background: linear-gradient(90deg, #7c3aed, #8b5cf6);
    border-color: transparent;
    color: white;
    box-shadow: 0 10px 22px rgba(124, 58, 237, 0.22);
  }

  html[data-theme='dark'] .preview-card {
    --preview-surface-top: rgba(19, 28, 49, 0.96);
    --preview-surface-bottom: rgba(10, 16, 32, 0.98);
    --preview-surface-accent: rgba(124, 58, 237, 0.22);
    --preview-shadow: 0 24px 46px rgba(0, 0, 0, 0.32);
    --preview-frame-border: rgba(167, 139, 250, 0.18);
    --preview-body-start: rgba(17, 24, 39, 0.98);
    --preview-body-end: rgba(30, 27, 56, 0.98);
    --preview-title-color: #f5f3ff;
    --preview-tag-color: #c4b5fd;
    --preview-muted: rgba(100, 116, 139, 0.28);
    --preview-selector-surface: rgba(17, 24, 39, 0.82);
    --preview-selector-border: rgba(167, 139, 250, 0.18);
    --preview-selector-shadow: 0 16px 30px rgba(0, 0, 0, 0.24);
  }

  html[data-theme='dark'] .image-selector-button {
    border-color: rgba(167, 139, 250, 0.2);
    background: rgba(124, 58, 237, 0.16);
    color: #ddd6fe;
  }

  html[data-theme='dark'] .image-selector-button:hover {
    background: rgba(124, 58, 237, 0.24);
  }

  @media (max-width: 50rem) {
    .preview-card {
      gap: 0.7rem;
    }

    .preview-card.mobile {
      width: min(100%, 15.25rem);
    }

    .preview-card.web {
      width: 100%;
    }

    .preview-frame.mobile {
      padding: 0.7rem;
    }

    .image-controls {
      bottom: 0.7rem;
    }

    .image-selector {
      gap: 0.45rem;
      padding: 0.4rem 0.45rem;
      grid-auto-columns: minmax(2rem, 2rem);
    }

    .image-selector-button {
      width: 2rem;
      height: 2rem;
      padding: 0;
    }

    .preview-frame.web {
      aspect-ratio: 4 / 3;
      padding: 0.85rem;
    }

    .preview-body {
      padding: 0.75rem;
    }

    .preview-body strong {
      font-size: 0.85rem;
    }
  }
</style>

<script>
  function initImageCarousels() {
    document.querySelectorAll('[data-image-carousel]').forEach((carousel) => {
      if (carousel.dataset.carouselReady === 'true') return;
      carousel.dataset.carouselReady = 'true';

      const track = carousel.querySelector('.image-track');
      const controls = carousel.querySelectorAll('[data-image-index]');
      const slides = carousel.querySelectorAll('.image-track img');

      if (!track || !controls.length || !slides.length) return;

      function setActive(index) {
        controls.forEach((control) => {
          const controlIndex = parseInt(control.dataset.imageIndex || '0', 10);
          control.classList.toggle('active', controlIndex === index);
        });
      }

      track.addEventListener('scroll', () => {
        const scrollPos = track.scrollLeft;
        const slideWidth = track.clientWidth;
        const activeIndex = Math.round(scrollPos / slideWidth);
        setActive(activeIndex);
      }, { passive: true });

      controls.forEach((control) => {
        control.addEventListener('click', () => {
          const idx = parseInt(control.dataset.imageIndex || '0', 10);
          track.scrollTo({ left: idx * track.clientWidth, behavior: 'smooth' });
          setActive(idx);
        });
      });

      setActive(0);
    });
  }

  initImageCarousels();
  document.addEventListener('astro:page-load', initImageCarousels);
</script>
